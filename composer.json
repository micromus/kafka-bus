{
    "name": "micromus/kafka-bus",
    "description": "This is my package kafka-bus",
    "keywords": [
        "Micromus",
        "kafka-bus"
    ],
    "homepage": "https://github.com/micromus/kafka-bus",
    "license": "MIT",
    "authors": [
        {
            "name": "Kirill Popkov",
            "email": "kirill.popkov.work@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-pcntl": "*",
        "ext-rdkafka": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^2.1",
        "testo/testo": "^0.10.2"
    },
    "autoload": {
        "psr-4": {
            "Micromus\\KafkaBus\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Micromus\\KafkaBus\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/php-cs-fixer fix --config .php-cs-fixer.php",
        "test": "vendor/bin/testo",
        "test-ci": "XDEBUG_MODE=coverage vendor/bin/testo --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,S
            "phpstan/extension-installer": true
        },
        "audit": {
            "abandoned": "report"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
